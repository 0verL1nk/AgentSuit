# Runtime selection
AGENTSUIT_BASE_AGENT=mock

# Claude Code adapter
# Set one of the supported Claude provider credentials when using
# `--base-agent claude-code`.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
AGENTSUIT_CLAUDE_MODEL=
AGENTSUIT_CLAUDE_WORKDIR=
AGENTSUIT_CLAUDE_PATH=

# IM / channel plugin exposure
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
AGENTSUIT_IM_STATE=memory

# Optional explicit exposure plugin modules. Comma-separated.
# If empty, `suit serve` discovers workspace plugins under `packages/`.
AGENTSUIT_EXPOSURE_PLUGIN_MODULES=
