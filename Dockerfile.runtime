FROM oven/bun:1.3.5

WORKDIR /workspace

COPY package.json bun.lock tsconfig.json ./
COPY packages ./packages
COPY examples ./examples

RUN bun install --frozen-lockfile

COPY scripts/docker-runtime-entrypoint.sh /usr/local/bin/agentsuit-runtime

RUN chmod +x /usr/local/bin/agentsuit-runtime \
  && mkdir -p /app/suit /app/state /app/reports

EXPOSE 8080

HEALTHCHECK CMD ["bun", "--eval", "const response = await fetch('http://127.0.0.1:8080/healthz'); if (!response.ok) process.exit(1);"]

ENTRYPOINT ["/usr/local/bin/agentsuit-runtime"]
CMD ["serve", "/app/suit", "--host", "0.0.0.0", "--port", "8080"]
