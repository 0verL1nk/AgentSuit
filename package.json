{
  "name": "agentsuit",
  "private": true,
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --workspaces build",
    "lint": "bunx @biomejs/biome check . && bun run --if-present --workspaces lint",
    "typecheck": "bun run --workspaces typecheck",
    "test": "bun test && bun run --workspaces test --if-present",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@agentsuit/cli": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  }
}
